@startuml
autonumber
skinparam shadowing false

actor Usuario
participant "Frontend\n(Login.jsx)" as FE
participant "API Service\n(api.js)" as API
participant "Backend\n/auth/login" as BE
participant "AuthController" as CTRL
participant "AuthService" as SVC
database "MySQL\nusuarios" as DB
participant "JWT" as JWT

Usuario -> FE: Ingresa email/password
FE -> API: login(email, password)
API -> BE: POST /auth/login
BE -> CTRL: login(req, res)
CTRL -> SVC: loginWithEmailPassword(email, password)
SVC -> DB: SELECT usuario por email
DB --> SVC: usuario + password_hash + rol + estado
SVC -> SVC: validar estado == Activo
SVC -> SVC: bcrypt.compare(password, hash)
SVC --> CTRL: safeUser
CTRL -> JWT: sign({id, rol}, secret, 8h)
JWT --> CTRL: token
CTRL --> BE: 200 { data: user, token }
BE --> API: respuesta JSON
API --> FE: { data, token }
FE -> FE: guardar token/user en localStorage

alt rol == owner
  FE -> Usuario: redirigir a /owner
else rol != owner
  FE -> Usuario: redirigir a /admin
end
@enduml
